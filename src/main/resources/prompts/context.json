{
  "workflow": {
    "STEP_1_GAP_CHECK": {
      "toolCalls": [
        {"tool": "getBlockInFuel", "params": {"regisNbr": "regisNbr"}, "assign": "blockInFuel"},
        {"tool": "getFirstFuelSlip", "params": {"regisNbr": "regisNbr"}, "assign": "fuelSlip"}
      ],
      "conditions": [
        {
          "if": "blockInFuel equals fuelSlip.preFob",
          "next": "STEP_3_LOCATION_CHECK"
        },
        {
          "else": "STEP_2_BLOCK_IN_VALIDATION"
        }
      ]
    },
    "STEP_2_BLOCK_IN_VALIDATION": {
      "toolCalls": [
        {"tool": "getInRangeRemainingFuel", "params": {"regisNbr": "regisNbr"}, "assign": "inRangeFuel"}
      ],
      "conditions": [
        {
          "if": "blockInFuel equals inRangeFuel",
          "action": "Correct remaining fuel calculation",
          "stop": true
        },
        {
          "else": "STEP_3_LOCATION_CHECK"
        }
      ]
    },
    "STEP_3_LOCATION_CHECK": {
      "toolCalls": [
        {"tool": "getAircraftLocation", "params": {"regisNbr": "regisNbr"}, "assign": "aircraftLocation"}
      ],
      "conditions": [
        {
          "if": "aircraftLocation does not equal fuelSlip.location",
          "action": "Verify fueling location and correct airport",
          "stop": true
        },
        {
          "else": "STEP_4_AIRCRAFT_CHECK"
        }
      ]
    },
    "STEP_4_AIRCRAFT_CHECK": {
      "toolCalls": [
        {"tool": "isWrongAircraft", "params": {"regisNbr": "regisNbr"}, "assign": "wrongAircraft"}
      ],
      "conditions": [
        {
          "if": "wrongAircraft is true",
          "action": "Verify aircraft registration in fuel slip",
          "stop": true
        },
        {
          "else": "STEP_5_GAP_TYPE"
        }
      ]
    },
    "STEP_5_GAP_TYPE": {
      "assign": {"gap": "fuelSlip.preFob minus blockInFuel"},
      "conditions": [
        {
          "if": "gap equals 0",
          "action": "Escalate for investigation",
          "stop": true
        },
        {
          "if": "gap greater than 0",
          "next": "STEP_6_MISSING_UPLIFT"
        },
        {
          "if": "gap less than 0",
          "next": "STEP_7_MISSING_APU"
        }
      ]
    },
    "STEP_6_MISSING_UPLIFT": {
      "toolCalls": [
        {"tool": "isMissingUpliftFuelSlip", "params": {"regisNbr": "regisNbr"}, "assign": "missingUplift"}
      ],
      "conditions": [
        {
          "if": "missingUplift is true",
          "action": "Create Uplift Fuel Slip",
          "stop": true
        },
        {
          "else": "STEP_8_FUEL_SLIP_VALIDATION"
        }
      ]
    },
    "STEP_7_MISSING_APU": {
      "toolCalls": [
        {"tool": "isMissingApuRunFuelSlip", "params": {"regisNbr": "regisNbr"}, "assign": "missingApu"}
      ],
      "conditions": [
        {
          "if": "missingApu is true",
          "action": "Create APU Run Fuel Slip",
          "stop": true
        },
        {
          "else": "STEP_8_FUEL_SLIP_VALIDATION"
        }
      ]
    },
    "STEP_8_FUEL_SLIP_VALIDATION": {
      "conditions": [
        {
          "if": "fuelSlip.computed less than fuelSlip.indicated",
          "action": "Correct Before FOB",
          "stop": true
        },
        {
          "if": "fuelSlip.computed greater than fuelSlip.indicated",
          "action": "Correct After FOB",
          "stop": true
        },
        {
          "if": "fuelSlip.meteredFuel less than 0 and fuelSlip.preFob less than fuelSlip.fob",
          "action": "Correct metered fuel value",
          "stop": true
        },
        {
          "if": "fuelSlip.density less than 6.31 or greater than 7.17",
          "action": "Correct density value",
          "stop": true
        },
        {
          "if": "fuelSlip.computed equals fuelSlip.indicated",
          "action": "Escalate",
          "stop": true
        }
      ]
    }
  }
}